menuconfig MOTOR
    bool "Motor drivers"
    help
      Enable support for motors.

if MOTOR

module = MOTOR
module-str = MOTOR
source "subsys/logging/Kconfig.template.log_config"

config MOTOR_COMMON
    bool "MOTOR COMMON"
    help
      Add support for common motor drivers
	select CAN

config LA_YINSHI
	bool "MOTOR LA YINSHI"
	help
	  Add support for Yinshi LA series electric cylinders
	select SERIAL

config MOTOR_DJI
    bool "MOTOR DJI"
    help
      Add support for dji motors
    select PID
    select MOTOR_COMMON

config MOTOR_DM
    bool "MOTOR DM"
    help
      Add support for dm motors
    select PID
    select MOTOR_COMMON

config MOTOR_MI
    bool "MOTOR MI"
    help
      Add support for mi motors
    select PID
    select MOTOR_COMMON

config MOTOR_RS
    bool "MOTOR RS"
    help
      Add support for rs motors
    select PID
    select MOTOR_COMMON

config MOTOR_VESC
    bool "MOTOR VESC"
    help
      Add support for vesc motors
    select MOTOR_COMMON

config MOTOR_LK
    bool "MOTOR LK"
    help
      Add support for lk motors
    select PID
    select MOTOR_COMMON

config MOTOR_LOG_LEVEL
    int "Motor log level"
    default 4
    help
      The log level of motor driver

config MOTOR_INIT_PRIORITY
    int "Motor init priority"
    default 90
    help
      The init priority of motor driver

config CAN_COUNT
    int "CAN count"
    default 2
    help
      The number of CAN devices

rsource "la_yinshi/Kconfig"
endif
