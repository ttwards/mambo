menuconfig MOTOR
    bool "Motor drivers"
    help
      Enable support for motors.

if MOTOR

module = MOTOR
module-str = MOTOR
source "subsys/logging/Kconfig.template.log_config"

config MOTOR_COMMON
    bool "MOTOR COMMON"
    help
      Add support for common motor drivers
	select CAN

config MOTOR_CAN_SCHED_REPLY_GUARD
	bool "Reserve CAN reply windows in motor scheduler"
	default y
	depends on MOTOR_COMMON
	help
	  Prevent the motor CAN scheduler from queueing another TX frame on the
	  same CAN controller immediately after a request frame that expects a
	  reply. This gives lower-priority motor reply frames a chance to win bus
	  arbitration under high load.

config MOTOR_CAN_SCHED_REPLY_GUARD_EXTRA_US
	int "Additional motor CAN reply guard time in microseconds"
	default 60
	depends on MOTOR_CAN_SCHED_REPLY_GUARD
	help
	  Extra time added after the calculated reply frame airtime. This covers
	  motor-side processing delay before the reply frame starts arbitration.

config MOTOR_DJI
    bool "MOTOR DJI"
    help
      Add support for dji motors
    select MOTOR_COMMON

config MOTOR_DM
    bool "MOTOR DM"
    help
      Add support for dm motors
    select MOTOR_COMMON

config MOTOR_MI
    bool "MOTOR MI"
    help
      Add support for mi motors
    select MOTOR_COMMON

config MOTOR_RS
    bool "MOTOR RS"
    help
      Add support for rs motors
    select MOTOR_COMMON

config MOTOR_VESC
    bool "MOTOR VESC"
    help
      Add support for vesc motors
    select MOTOR_COMMON

config MOTOR_LK
    bool "MOTOR LK"
    help
      Add support for lk motors
    select MOTOR_COMMON

config MOTOR_LOG_LEVEL
    int "Motor log level"
    default 4
    help
      The log level of motor driver

config MOTOR_INIT_PRIORITY
    int "Motor init priority"
    default 90
    help
      The init priority of motor driver

config CAN_COUNT
    int "CAN count"
    default 2
    help
      The number of CAN devices
endif
