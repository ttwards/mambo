/ {
	motor {
		dm_motor: dm_motor{
			compatible = "dm,motor";
			id = <1>;
			rx_id = <0x00>;
			tx_id = <0x01>;
			v_max = "785";
			status = "okay";
			can_channel = <&can1>;
			controllers = <&mit>;
			t_max = "5";
			freq = <1000>;
		};
	};
	mit: mit{
		compatible = "motor-controller,mit";
		k_p = "2";
		k_d = "0.5";
	};
};
